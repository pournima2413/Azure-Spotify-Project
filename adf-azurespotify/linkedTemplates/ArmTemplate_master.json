{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adf-azurespotify"
		},
		"azure_spotify_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'azure_spotify'"
		},
		"datalake_spotify_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'datalake_spotify'"
		},
		"azure_spotify_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "sql-azure-spotify.database.windows.net"
		},
		"azure_spotify_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "adminpournima"
		},
		"azure_spotify_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "adminpournimadb"
		},
		"datalake_spotify_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://storageazurespotify.dfs.core.windows.net/"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "adf-azurespotify_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"azure_spotify_password": {
						"value": "[parameters('azure_spotify_password')]"
					},
					"datalake_spotify_accountKey": {
						"value": "[parameters('datalake_spotify_accountKey')]"
					},
					"azure_spotify_properties_typeProperties_server": {
						"value": "[parameters('azure_spotify_properties_typeProperties_server')]"
					},
					"azure_spotify_properties_typeProperties_database": {
						"value": "[parameters('azure_spotify_properties_typeProperties_database')]"
					},
					"azure_spotify_properties_typeProperties_userName": {
						"value": "[parameters('azure_spotify_properties_typeProperties_userName')]"
					},
					"datalake_spotify_properties_typeProperties_url": {
						"value": "[parameters('datalake_spotify_properties_typeProperties_url')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}